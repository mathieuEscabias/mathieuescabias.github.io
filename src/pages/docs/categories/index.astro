---
import CategoriesLayout from "@components/docs/CategoriesLayout.astro";
import { getTaxa, getTaxaMultiset } from "@lib/taxonomyParser";

const collection = "docs";
const taxonomy = "categories";
const taxa = await getTaxa(collection, taxonomy);
const allTaxa = await getTaxaMultiset(collection, taxonomy);
---

<CategoriesLayout taxonomy={taxonomy} taxa={taxa} allTaxa={allTaxa} />