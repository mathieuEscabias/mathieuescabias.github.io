---
import type { DocsEntry } from "@/types";
import { getEntries } from "@lib/contentParser";
import { getTaxa } from "@lib/taxonomyParser";
import taxonomyFilter from "@lib/taxonomyFilter";
import TaxonomyLayout from "@components/docs/TaxonomyLayout.astro";

export async function getStaticPaths() {
  const taxa = await getTaxa("docs", "categories");
  const paths = taxa.map((taxon) => ({
    params: {
      category: taxon,
    },
    props: { taxon },
  }));
  return paths;
}

const { taxon } = Astro.props;
const entries = await getEntries("docs") as DocsEntry[];
const filteredEntries: DocsEntry[] = taxonomyFilter(entries, "categories", taxon!);
---

<TaxonomyLayout taxonomy="categories" taxa={[taxon]} allTaxa={[taxon]} entries={filteredEntries} activeTaxon={taxon} />
